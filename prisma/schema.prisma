generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// ENUMS
// ==========================

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  INSURANCE
  OTHER
}

enum DocumentType {
  REGISTRATION_CERTIFICATE
  INSURANCE
  PERMIT
  POLLUTION_CERTIFICATE
  FITNESS
  OTHER
}

enum ReminderEntityType {
  DRIVER_LICENSE
  VEHICLE_DOCUMENT
}

// ==========================
// MODELS
// ==========================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(FLEET_MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@map("users")
}

model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  vehicleName        String
  model              String
  vehicleType        String
  region             String
  maxLoadCapacity    Float
  odometer           Float         @default(0)
  acquisitionCost    Float
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  documents       VehicleDocument[]

  @@index([status])
  @@map("vehicles")
}

model Driver {
  id                String       @id @default(cuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float        @default(100)
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  trips Trip[]

  @@index([status])
  @@map("drivers")
}

model Trip {
  id              String     @id @default(cuid())
  vehicleId       String
  driverId        String
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  fuelUsed        Float?
  revenue         Float?
  startTime       DateTime?
  endTime         DateTime?
  status          TripStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceLog {
  id              String            @id @default(cuid())
  vehicleId       String
  maintenanceType String
  description     String
  cost            Float
  date            DateTime
  status          MaintenanceStatus @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([vehicleId])
  @@map("maintenance_logs")
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  liters    Float
  cost      Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("fuel_logs")
}

model Expense {
  id          String      @id @default(cuid())
  vehicleId   String
  expenseType ExpenseType
  amount      Float
  description String
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([expenseType])
  @@map("expenses")
}

model VehicleDocument {
  id             String       @id @default(cuid())
  vehicleId      String
  docType        DocumentType
  documentNumber String?
  documentUrl    String
  expiryDate     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([expiryDate])
  @@map("vehicle_documents")
}

// Tracks which expiry-threshold reminder (30/15/7/0 days) has already been
// sent for a driver license or vehicle document, so the daily cron never
// re-sends the same notice twice.
model ReminderLog {
  id            String             @id @default(cuid())
  entityType    ReminderEntityType
  entityId      String
  thresholdDays Int
  sentAt        DateTime           @default(now())

  @@unique([entityType, entityId, thresholdDays])
  @@index([entityId])
  @@map("reminder_logs")
}
